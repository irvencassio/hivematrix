# HiveMatrix License Service — Environment Variables
# Copy to .env.local (local dev) or configure in Vercel project settings (production).
# NEVER commit a filled-in copy of this file.

# Ed25519 private key for signing license files.
# Source: ~/.hivematrix/keys/license-ed25519-private.pem (from scripts/license-keygen.mts)
# Paste the full PEM including header/footer; use \n for newlines in Vercel.
HIVEMATRIX_LICENSE_PRIVATE_KEY_PEM=

# Ed25519 public key (baked into the daemon via LICENSE_ISSUER_PUBLIC_KEY_PEM in license.ts).
# Kept here for reference and for the test harness.
HIVEMATRIX_LICENSE_PUBLIC_KEY_PEM=

# Lemon Squeezy webhook signing secret.
# Source: Settings → Webhooks → <your webhook> → Signing Secret
LEMON_WEBHOOK_SECRET=

# Lemon Squeezy API key (optional; only needed for direct API calls, not webhook-only operation).
# Source: Settings → API → Create API key
LEMON_API_KEY=

# Lemon Squeezy variant IDs for tier mapping.
# Source: Product pages → Variants section after creating products.
LEMON_VARIANT_MONTHLY=
LEMON_VARIANT_ANNUAL=

# Email delivery via Resend (https://resend.com — free tier sufficient).
RESEND_API_KEY=
RESEND_FROM=HiveMatrix <licenses@hivematrix.app>

# Grace period in days (default: 30). Overrides the value baked into issued licenses.
LICENSE_GRACE_DAYS=30
