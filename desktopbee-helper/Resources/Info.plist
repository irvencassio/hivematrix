<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleName</key>
  <string>DesktopBeeHelper</string>
  <key>CFBundleDisplayName</key>
  <string>HiveMatrix Desktop Lane Helper</string>
  <key>CFBundleIdentifier</key>
  <string>com.hivematrix.desktopbee.helper</string>
  <key>CFBundleVersion</key>
  <string>0.1.0</string>
  <key>CFBundleShortVersionString</key>
  <string>0.1.0</string>
  <key>CFBundlePackageType</key>
  <string>APPL</string>
  <key>CFBundleExecutable</key>
  <string>DesktopBeeHelper</string>
  <key>LSMinimumSystemVersion</key>
  <string>14.0</string>
  <!-- Background daemon: no Dock icon, no menu bar presence. -->
  <key>LSUIElement</key>
  <true/>
  <key>LSBackgroundOnly</key>
  <true/>
  <!-- TCC usage descriptions (shown in the permission prompts). -->
  <key>NSAppleEventsUsageDescription</key>
  <string>HiveMatrix Desktop Lane controls scriptable apps on your behalf, with your approval.</string>
  <!-- EventKit (calendar subcommand, P0.1): reads/creates calendar events via
       EKEventStore.requestFullAccessToEvents. This is a clean EventKit TCC
       grant attributed to this helper binary — it does NOT go through
       AppleScript/"tell application Calendar" and does not launch
       Calendar.app. No sandbox/entitlement is needed beyond this usage
       string on a non-sandboxed, hardened-runtime Developer ID build. -->
  <key>NSCalendarsFullAccessUsageDescription</key>
  <string>HiveMatrix reads and creates your calendar events on your behalf, with your approval.</string>
  <!-- EventKit (reminders subcommand): reads/creates reminders via
       EKEventStore.requestFullAccessToReminders. Same clean EventKit TCC
       grant as Calendars above, attributed to this helper binary, and does
       NOT go through AppleScript/"tell application Reminders" — it does not
       launch Reminders.app. This is a separate macOS permission from
       Calendars; the operator will see its own one-time system prompt. -->
  <key>NSRemindersFullAccessUsageDescription</key>
  <string>HiveMatrix reads and creates your reminders when you ask.</string>
</dict>
</plist>
