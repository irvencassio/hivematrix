<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Hardened runtime + ability to send Apple events (Automation) if the
       operator later grants it. Accessibility + Screen Recording are TCC
       grants, not entitlements, so they need no key here. -->
  <key>com.apple.security.automation.apple-events</key>
  <true/>
</dict>
</plist>
