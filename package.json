{
  "name": "hivematrix",
  "version": "0.1.70",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --import tsx/esm --test 'src/**/*.test.ts' 'scripts/**/*.test.mjs'",
    "test:watch": "node --import tsx/esm --test --watch 'src/**/*.test.ts' 'scripts/**/*.test.mjs'",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "scope-wall": "node scripts/scope-wall.mjs",
    "build:daemon": "node scripts/build-daemon.mjs",
    "verify:daemon-runtime": "node scripts/verify-daemon-runtime.mjs",
    "release:verify": "tsx scripts/verify-autoupdate-release.mts"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "chokidar": "^5.0.0",
    "dotenv": "^17.3.1",
    "mermaid": "^11.15.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "esbuild": "^0.28.1",
    "tsx": "^4.21.0",
    "typescript": "5.9.3"
  }
}
