{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HiveMatrix",
  "version": "0.1.0",
  "identifier": "com.hivematrix.app",
  "build": {
    "frontendDist": "../ui",
    "devUrl": "http://127.0.0.1:3747",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "HiveMatrix",
        "width": 1280,
        "height": 840,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "Developer ID Application: Irven Cassio (8B3CHTY93V)",
      "hardenedRuntime": true,
      "minimumSystemVersion": "12.0"
    }
  }
}
