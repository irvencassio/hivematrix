<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Entitlements for the BUNDLED Node binary (Contents/Resources/daemon/bin/node)
  under hardened runtime:
    allow-jit + allow-unsigned-executable-memory  — V8's JIT
    disable-library-validation  — lets node dlopen better_sqlite3.node (a
      separately-signed native addon); without it amfid kills the load and the
      daemon crash-loops under launchd even after notarization.
-->
<plist version="1.0">
<dict>
  <key>com.apple.security.cs.allow-jit</key><true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key><true/>
  <key>com.apple.security.cs.disable-library-validation</key><true/>
</dict>
</plist>
